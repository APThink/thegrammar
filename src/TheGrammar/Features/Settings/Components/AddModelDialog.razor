<MudDialog>
    <DialogContent>
        <div style="display: flex; flex-direction: column; gap: 16px;">
            <MudTextField @bind-Value="_key" T="string" Label="Key" HelperText="Unique identifier (e.g. gpt-4o)" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_displayName" T="string" Label="Display Name" HelperText="Name shown in the dropdown" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_modelName" T="string" Label="Model Name" HelperText="OpenAI model id (e.g. gpt-4o, models are here https://developers.openai.com/api/docs/models)" Variant="Variant.Outlined" />
            <MudNumericField @bind-Value="_temperature" T="float?" Label="Temperature" HelperText="Leave empty for default" Min="0" Max="2" Step="0.1f" />
            <MudNumericField @bind-Value="_topP" T="float" Label="Top P" Min="0" Max="1" Step="0.1f" />
            <MudNumericField @bind-Value="_frequencyPenalty" T="float" Label="Frequency Penalty" Min="-2" Max="2" Step="0.1f" />
            <MudNumericField @bind-Value="_presencePenalty" T="float" Label="Presence Penalty" Min="-2" Max="2" Step="0.1f" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Cancel" OnClick="Cancel" IconColor="Color.Secondary" Size="Size.Large">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" OnClick="Submit" IconColor="Color.Primary" Size="Size.Large" Disabled="_isValidating">
            @if (_isValidating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Validating...</span>
            }
            else
            {
                <span>Save</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>