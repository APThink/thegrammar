@page "/prompts"

<MudText Typo="Typo.h6" Style="padding-bottom: 25px">Prompt Key Bindings</MudText>

<CascadingValue Value="PromptRepository">
    <MudCard>
        <MudCardContent>
            <PromptView Prompts="@prompts"></PromptView>
        </MudCardContent>

        <MudCardActions Style="justify-content: flex-end;">
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="AddPrompt" IconColor="Color.Primary"
                       Size="Size.Large">Add new prompt key binding
            </MudButton>
        </MudCardActions>
    </MudCard>
</CascadingValue>